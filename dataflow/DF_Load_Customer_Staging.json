{
	"name": "DF_Load_Customer_Staging",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_Customer",
						"type": "DatasetReference"
					},
					"name": "SourceCSV"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_AzureSQLDB",
						"type": "LinkedServiceReference"
					},
					"name": "SinkStaging"
				}
			],
			"transformations": [
				{
					"name": "AddAuditColumns"
				},
				{
					"name": "SelectColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Index as short,",
				"          {Customer Id} as string,",
				"          {First Name} as string,",
				"          {Last Name} as string,",
				"          Company as string,",
				"          City as string,",
				"          Country as string,",
				"          {Phone 1} as string,",
				"          {Phone 2} as string,",
				"          Email as string,",
				"          {Subscription Date} as date,",
				"          Website as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceCSV",
				"SourceCSV derive(CustomerID = toInteger(byName('Index')),",
				"          CustomerName = concat(byName('First Name'), ' ', byName('Last Name')),",
				"          Email = byName('Email'),",
				"          City = byName('City'),",
				"          Country = byName('Country'),",
				"          Company = byName('Company'),",
				"          {_LoadDate} = currentDate()) ~> AddAuditColumns",
				"AddAuditColumns select(mapColumn(",
				"          Company,",
				"          City,",
				"          Country,",
				"          Email,",
				"          CustomerID,",
				"          CustomerName,",
				"          {_LoadDate}",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectColumns",
				"SelectColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          City as string,",
				"          {_LoadDate} as date,",
				"          {_SourceFile} as string",
				"     ),",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'stg_customer',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     truncate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> SinkStaging"
			]
		}
	}
}